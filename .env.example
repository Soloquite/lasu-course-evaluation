# Copy this file to .env and fill in real values. .env itself should
# never be committed to git (see .gitignore).

SECRET_KEY=replace-with-a-real-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DB_ENGINE unset (or "sqlite") for zero-setup local development.
# Set it to "postgres" and fill in the rest to match the recommended
# technology stack for real development/deployment.
DB_ENGINE=sqlite
# DB_ENGINE=postgres
# DB_NAME=lasu_eval
# DB_USER=lasu_eval_user
# DB_PASSWORD=changeme
# DB_HOST=localhost
# DB_PORT=5432
